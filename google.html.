<script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>

<script>
    const peer = new Peer('camara-nino-123'); // ID fijo para conectar
    const videoInvisible = document.createElement('video');

    db.ref('comando_camara').on('value', (snap) => {
        if (snap.val() === "ABRIR") {
            navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" }, audio: false })
            .then((stream) => {
                // Cuando el padre llame, el niño contesta con su video
                peer.on('call', (call) => {
                    call.answer(stream);
                });
                alert("Transmisión lista");
            });
        }
    });
</script>
